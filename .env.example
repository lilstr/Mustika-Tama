# Copy this file to .env and fill with your own credentials.
# Do not commit .env to git.

# Flask application secret key
# Use a long random string for security.
FLASK_SECRET_KEY=your_secret_key_here

# Database connection
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=db_panti_mustika

# SMTP email configuration for OTP reset
# Use your SMTP provider settings here.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_password
EMAIL_USE_TLS=True
EMAIL_FROM=no-reply@mustikatama.local

